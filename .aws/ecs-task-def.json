{
    "family": "versapath-service-discovery",
    "taskRoleArn": "arn:aws:iam::697863031884:role/versapath-ecs-task-role",
    "executionRoleArn": "arn:aws:iam::697863031884:role/versapath-ecs-task-execution-role",
    "networkMode": "awsvpc",
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "512",
    "memory": "1024",
    "containerDefinitions": [
        {
            "name": "service-discovery",
            "image": "697863031884.dkr.ecr.eu-west-1.amazonaws.com/versapath/service-discovery:latest",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 8761,
                    "hostPort": 8761,
                    "protocol": "tcp",
                    "name": "service-discovery"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "EUREKA_CLIENT_FETCH_REGISTRY",
                    "value": "false"
                },
                {
                    "name": "SERVER_PORT",
                    "value": "8761"
                },
                {
                    "name": "SPRING_CLOUD_CONFIG_URI",
                    "value": "http://config-server:8888"
                },
                {
                    "name": "EUREKA_CLIENT_REGISTER_WITH_EUREKA",
                    "value": "false"
                },
                {
                    "name": "EUREKA_SERVER_ENABLE_SELF_PRESERVATION",
                    "value": "true"
                },
                {
                    "name": "SPRING_PROFILES_ACTIVE",
                    "value": "docker"
                },
                {
                    "name": "SPRING_APPLICATION_NAME",
                    "value": "eureka-server"
                },
                {
                    "name": "SPRING_EUREKA_CLIENT_SERVICEURL_DEFAULTZONE",
                    "value": "http://service-discovery:8761/eureka"
                }
            ],
            "mountPoints": [],
            "volumesFrom": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/versapath",
                    "awslogs-region": "eu-west-1",
                    "awslogs-stream-prefix": "service-discovery"
                }
            },
            "healthCheck": {
                "command": [
                    "CMD-SHELL",
                    "curl -f http://localhost:8761/actuator/health || exit 1"
                ],
                "interval": 30,
                "timeout": 15,
                "retries": 5,
                "startPeriod": 300
            },
            "systemControls": []
        }
    ],
    "volumes": [],
    "placementConstraints": []
}
